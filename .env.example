# API Configuration for Resume Screening Agent

# REQUIRED: OpenAI API Key (for text analysis and ranking)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL: HuggingFace API Token (for visual analysis with LLaVA-1.5)
# Only needed if enable_visual_analysis = true in config.ini
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Instructions:
# 1. For Text-Only Mode (uses OpenAI GPT-4o):
#    - Only set OPENAI_API_KEY
#    - Set enable_visual_analysis = false in config.ini
#
# 2. For Hybrid Mode (Text + Visual):
#    - Set both OPENAI_API_KEY and HUGGINGFACE_API_TOKEN
#    - Set enable_visual_analysis = true in config.ini
#
# 3. Save this file as '.env' (remove .example extension)

# Examples:
# OPENAI_API_KEY=sk-proj-abc123xyz789...
# HUGGINGFACE_API_TOKEN=hf_abc123xyz789...
